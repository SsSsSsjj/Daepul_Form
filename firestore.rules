rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function creatorSignedIn() {
      return signedIn() && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function ownsForm(formId) {
      return signedIn()
        && get(/databases/$(database)/documents/forms/$(formId)).data.ownerUid == request.auth.uid;
    }

    function canManageForm(formId) {
      let form = get(/databases/$(database)/documents/forms/$(formId)).data;
      return signedIn() && (
        form.ownerUid == request.auth.uid
        || (
          'collaborators' in form
          && form.collaborators[request.auth.uid] in ['viewer', 'editor']
        )
      );
    }

    function canEditForm(formId) {
      let form = get(/databases/$(database)/documents/forms/$(formId)).data;
      return signedIn() && (
        form.ownerUid == request.auth.uid
        || (
          'collaborators' in form
          && form.collaborators[request.auth.uid] == 'editor'
        )
      );
    }

    function participantAllowed(form) {
      let email = request.auth.token.email;
      return !('settings' in form)
        ? request.auth.token.firebase.sign_in_provider != 'anonymous'
        : form.settings.access.participation == 'anyone'
          || (form.settings.access.participation == 'authenticated' && request.auth.token.firebase.sign_in_provider != 'anonymous')
          || (form.settings.access.participation == 'kangnam' && request.auth.token.email_verified == true && email.matches('.*@kangnam[.]ac[.]kr$'))
          || (form.settings.access.participation == 'allowlist' && request.auth.token.email_verified == true && email in form.settings.access.allowedEmails);
    }

    match /oauthStates/{stateId} {
      allow read, write: if false;
    }

    match /oauthExchanges/{exchangeId} {
      allow read, write: if false;
    }

    match /forms/{formId} {
      allow create: if creatorSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.creatorUid == request.auth.uid
        && request.resource.data.formId == formId;
      allow read: if signedIn() && (resource.data.published == true || canManageForm(formId));
      allow update: if canEditForm(formId)
        && request.resource.data.ownerUid == resource.data.ownerUid
        && (
          ('creatorUid' in resource.data && request.resource.data.creatorUid == resource.data.creatorUid)
          || (!('creatorUid' in resource.data) && request.resource.data.creatorUid == resource.data.ownerUid)
        )
        && (
          ('formId' in resource.data && request.resource.data.formId == resource.data.formId)
          || (!('formId' in resource.data) && request.resource.data.formId == formId)
        )
        && (
          ('responseCount' in resource.data && request.resource.data.responseCount == resource.data.responseCount)
          || (!('responseCount' in resource.data) && request.resource.data.responseCount == 0)
        );
      allow delete: if ownsForm(formId);

      match /responses/{responseId} {
        function form() {
          return get(/databases/$(database)/documents/forms/$(formId)).data;
        }

        // Submission creation and edits go through the callable transaction,
        // which atomically validates schedule, capacity, access, and duplicates.
        allow create, update: if false;
        // Respondents need to read only their own document so the client can
        // detect an existing submission before attempting an immutable create.
        allow get: if canManageForm(formId)
          || (signedIn() && (
            responseId == request.auth.uid
            || resource.data.respondentUid == request.auth.uid
            || resource.data.anonymousId == request.auth.uid
          ));
        allow list: if canManageForm(formId);
        allow delete: if canEditForm(formId);
      }

      match /drafts/{actorId} {
        allow read, create, update, delete: if signedIn() && actorId == request.auth.uid;
      }

      match /analysis/{analysisId} {
        allow read, create, update: if canManageForm(formId);
        allow delete: if canEditForm(formId);
      }

      match /versions/{versionId} {
        allow read, create: if canManageForm(formId);
        allow update, delete: if false;
      }
    }

    match /formDrafts/{draftId} {
      allow create: if creatorSignedIn() && request.resource.data.creatorUid == request.auth.uid;
      allow read, delete: if creatorSignedIn() && resource.data.creatorUid == request.auth.uid;
      allow update: if creatorSignedIn()
        && resource.data.creatorUid == request.auth.uid
        && request.resource.data.creatorUid == resource.data.creatorUid;
    }

    match /formSlugs/{slugId} {
      allow read, write: if false;
    }
  }
}
