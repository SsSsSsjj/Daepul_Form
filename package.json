{
  "name": "daepul-form-prototype",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:functions": "npm --prefix functions run build",
    "lint": "eslint .",
    "security:scan": "node scripts/check-secrets.mjs",
    "test": "vitest run",
    "test:firestore-rules": "firebase emulators:exec --project daepulform-rules-test --only auth,firestore \"node test/firestore-rules.mjs\"",
    "test:functions": "npm --prefix functions test",
    "test:functions:emulator": "firebase emulators:exec --only functions,firestore \"node functions/test/emulator-smoke.mjs\"",
    "preview": "vite preview"
  },
  "dependencies": {
    "@rhwp/core": "^0.7.19",
    "@tanstack/react-virtual": "^3.14.8",
    "firebase": "^12.16.0",
    "lucide-react": "^0.525.0",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "write-excel-file": "^4.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.0.10",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.30.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^29.1.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.4",
    "vitest": "^4.1.10"
  }
}
