rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function ownsForm(formId) {
      return signedIn()
        && firestore.get(/databases/(default)/documents/forms/$(formId)).data.ownerUid == request.auth.uid;
    }

    function canManageForm(formId) {
      let form = firestore.get(/databases/(default)/documents/forms/$(formId)).data;
      return signedIn() && (
        form.ownerUid == request.auth.uid
        || (
          'collaborators' in form
          && form.collaborators[request.auth.uid] in ['viewer', 'editor']
        )
      );
    }

    match /response-files/{formId}/{actorId}/{fileName} {
      allow create: if signedIn()
        && actorId == request.auth.uid
        && request.resource.size <= 20 * 1024 * 1024;
      allow read: if canManageForm(formId) || (signedIn() && actorId == request.auth.uid);
      allow update: if false;
      allow delete: if ownsForm(formId) || (signedIn() && actorId == request.auth.uid);
    }
  }
}
